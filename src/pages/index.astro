---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import SectionBlock from '../components/SectionBlock.astro';
import { sanityClient, portableTextToHtml, urlForImage } from '../utils/sanity';

let content = null;
let events = [];

try {
  content = await sanityClient.fetch(`*[_type == "homepage" && (_id == "homepage" || _id == "drafts.homepage")] | order(_updatedAt desc)[0]{
    heroHeadline,
    heroSection,
    deriskingSection,
    engageSection,
    whenSection,
    aboutSection
  }`);
  
  events = await sanityClient.fetch(`*[_type == "event"] | order(date asc){
    "id": _id,
    title,
    date,
    description,
    link
  }`);
} catch (e) {
  console.error("Failed to fetch content from Sanity CMS:", e);
}

const homepage = content || {};
const finalEvents = events || [];

const heroHeadline = homepage.heroHeadline;
const heroSec = homepage.heroSection;
const deriskingSec = homepage.deriskingSection;
const engageSec = homepage.engageSection;
const whenSec = homepage.whenSection;
const aboutSec = homepage.aboutSection;
---

<Layout title="Strategic Agility & Flow Simulations" description="Measure and improve strategic agility and collaboration through experiential simulation dojos.">
  
  <!-- Hero / Attention Grabber Section -->
  <header class="hero-section" id="hero">
    <div class="hero-overlay"></div>
    <div class="container hero-inner">
      {heroHeadline && (
        <h1 class="hero-headline">
          {heroHeadline}
        </h1>
      )}
      
      {/* Hero Section Content Layout: text1, image1, text2, image2, text3 */}
      {heroSec && (
        <div class="hero-content-flow">
          {heroSec.text1 && heroSec.text1.length > 0 && (
            <div class="hero-text">
              <Fragment set:html={portableTextToHtml(heroSec.text1)} />
            </div>
          )}
          {heroSec.image1 && (
            <div class="hero-image">
              <img src={urlForImage(heroSec.image1)} alt={heroSec.image1?.alt || 'Hero Image'} />
            </div>
          )}
          {heroSec.text2 && heroSec.text2.length > 0 && (
            <div class="hero-text">
              <Fragment set:html={portableTextToHtml(heroSec.text2)} />
            </div>
          )}
          {heroSec.image2 && (
            <div class="hero-image">
              <img src={urlForImage(heroSec.image2)} alt={heroSec.image2?.alt || 'Hero Image'} />
            </div>
          )}
          {heroSec.text3 && heroSec.text3.length > 0 && (
            <div class="hero-text">
              <Fragment set:html={portableTextToHtml(heroSec.text3)} />
            </div>
          )}
        </div>
      )}

      <div class="scroll-down-container">
        <a href="#de-risking" class="scroll-down-btn" aria-label="Scroll to De-risking section">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </a>
      </div>
    </div>
  </header>

  <!-- De-risking Section -->
  <SectionBlock
    id="de-risking"
    title="De-risking"
    section={deriskingSec}
    bgClass="section-light"
  />

  <!-- How We Engage Section -->
  <SectionBlock
    id="how-we-engage"
    title="How we engage"
    section={engageSec}
    bgClass="section-soft"
  />

  <!-- Is This For You Section -->
  <SectionBlock
    id="is-this-for-you"
    title="Is this for you?"
    section={whenSec}
    bgClass="section-light"
  />

  <!-- About Section -->
  <SectionBlock
    id="about"
    title="About"
    section={aboutSec}
    bgClass="section-soft"
  />

  <!-- Upcoming Events Section -->
  <section class="section section-light" id="events">
    <div class="container">
      <div class="section-header text-center">
        <h2>Upcoming Events</h2>
        <p class="section-subheader">Join our live simulation workshops and dojo training sessions.</p>
      </div>

      {finalEvents.length > 0 ? (
        <div class="grid-2 events-grid">
          {finalEvents.map(event => (
            <div class="card event-card">
              <div class="event-meta">
                <span class="event-date">
                  {new Date(event.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </span>
              </div>
              <h3>{event.title}</h3>
              {event.description && <p class="event-desc">{event.description}</p>}
              {event.link && (
                <a href={event.link} target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-sm event-link" id={`btn-event-${event.id || event._id}`}>
                  Register Now &rarr;
                </a>
              )}
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-events text-center">
          <p>No upcoming events currently scheduled. Check back soon!</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .text-center {
    text-align: center;
  }
  
  /* Hero Section Styling */
  .hero-section {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 11rem 2rem 7rem;
    background-color: var(--color-bg-dark-hero);
    overflow: hidden;
  }
  
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(227, 89, 61, 0.12) 0%, rgba(37, 52, 55, 0) 70%);
    pointer-events: none;
    z-index: 1;
  }
  
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: var(--container-narrow-width);
  }
  
  .hero-headline {
    font-size: clamp(2.3rem, 5.2vw, 3.8rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-neutral-white);
    margin-bottom: var(--space-md);
  }
  
  .hero-content-flow {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .hero-text p,
  .hero-text :global(p) {
    font-size: clamp(1.1rem, 1.5vw, 1.25rem);
    line-height: 1.65;
    color: var(--color-neutral-white) !important;
    margin-bottom: 0;
  }

  .hero-image img {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: var(--radius-md);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }
  
  .scroll-down-container {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }

  .scroll-down-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    border: 1.5px solid rgba(255, 255, 255, 0.25);
    color: var(--color-neutral-white);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    animation: scroll-bounce 2.2s infinite;
    cursor: pointer;
  }

  .scroll-down-btn:hover {
    background: var(--color-brand-red);
    border-color: var(--color-brand-red);
    color: var(--color-neutral-white);
    transform: translateY(3px) scale(1.05);
    box-shadow: 0 8px 24px rgba(227, 89, 61, 0.4);
    animation-play-state: paused;
  }

  @keyframes scroll-bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateY(0);
    }
    40% {
      transform: translateY(6px);
    }
    60% {
      transform: translateY(3px);
    }
  }
  
  /* Events Grid Styling */
  .section-header {
    max-width: 600px;
    margin: 0 auto var(--space-xl);
  }
  
  .section-subheader {
    font-size: 1.1rem;
    color: var(--color-text-dark-muted);
  }
  
  .events-grid {
    align-items: stretch;
  }
  
  .event-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
  }
  
  .event-meta {
    margin-bottom: var(--space-xs);
  }
  
  .event-date {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-brand-red);
    letter-spacing: 0.05em;
  }
  
  .event-card h3 {
    font-size: 1.35rem;
    margin-bottom: var(--space-xs);
  }
  
  .event-desc {
    font-size: 0.98rem;
    flex-grow: 1;
    color: var(--color-text-dark-muted);
    margin-bottom: var(--space-md);
  }
  
  .event-link {
    align-self: flex-start;
    padding: var(--space-xs) var(--space-sm);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .empty-events p {
    font-size: 1.05rem;
    color: var(--color-text-dark-muted);
    font-style: italic;
  }
</style>
