---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = "Measure and scale agile through experiential simulation dojos. Okaloa helps leading teams improve strategic agility." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Optimization -->
    <title>{title} | Okaloa</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | Okaloa`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    
    <!-- Google Fonts Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- Sticky Navigation Header (Scroll-sensitive) -->
    <nav id="main-nav">
      <div class="nav-container">
        <a href="#hero" class="nav-left" id="nav-logo">
          <!-- Logo Light for dark hero background, Logo Dark for scrolled white header -->
          <img src="/images/okaloa-logo-reverse.png" class="logo-light" alt="Okaloa Logo" height="32" />
          <img src="/images/okaloa-logo-dark.png" class="logo-dark" alt="Okaloa Logo" height="32" />
        </a>
        
        <ul class="nav-links" id="nav-links">
          <li><a href="#de-risking" class="nav-item">De-risking</a></li>
          <li><a href="#how-we-engage" class="nav-item">How we engage</a></li>
          <li><a href="#is-this-for-you" class="nav-item">Is this for you</a></li>
          <li><a href="#about" class="nav-item">About</a></li>
          <li><a href="#events" class="nav-item">Upcoming Events</a></li>
          <li class="nav-contact-wrapper">
            <a href="mailto:info@okaloa.com?subject=Contact" class="contact-btn" id="nav-contact-btn">Contact</a>
            <div id="contact-popover" class="contact-popover" aria-hidden="true">
              <div class="popover-content">
                <span class="popover-email" id="email-address">info@okaloa.com</span>
                <div class="popover-actions">
                  <button class="popover-btn popover-copy-btn" id="copy-email-btn" aria-label="Copy email address">
                    <span class="copy-btn-text">Copy</span>
                  </button>
                  <a href="mailto:info@okaloa.com?subject=Contact" class="popover-btn popover-mail-btn" aria-label="Open in email application">
                    Email Us
                  </a>
                </div>
              </div>
              <div class="popover-arrow"></div>
            </div>
          </li>
        </ul>
        
        <button class="nav-toggle" id="mobile-nav-toggle" aria-label="Toggle Navigation">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer (Classic Dark Grey style) -->
    <footer class="main-footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <img src="/images/okaloa-logo-reverse.png" alt="Okaloa Logo" height="32" class="footer-logo-img" />
          <p class="footer-tagline">Scaling strategic agility and flow through experiential learning dojos.</p>
        </div>
        
        <div class="footer-nav">
          <h4>Navigation</h4>
          <ul>
            <li><a href="#de-risking">De-risking</a></li>
            <li><a href="#how-we-engage">How we engage</a></li>
            <li><a href="#is-this-for-you">Is this for you</a></li>
            <li><a href="#about">About Us</a></li>
          </ul>
        </div>
        
        <div class="footer-contact">
          <h4>Contact Us</h4>
          <p>Egelantierlaan 17<br />1851 Humbeek, Belgium</p>
          <p>VAT: BE0478.205.050</p>
          <div class="contact-methods">
            <a href="tel:+32473565098" id="footer-phone" class="contact-link">Phone: +32 473 56 50 98</a>
            <a href="mailto:info@okaloa.com?subject=Inquiry" id="footer-email" class="contact-link">Email: info@okaloa.com</a>
          </div>
        </div>
      </div>
      
      <div class="container footer-bottom">
        <p>&copy; {new Date().getFullYear()} Okaloa. All rights reserved.</p>
      </div>
    </footer>

    <!-- Interactive script for sticky navbar, mobile menu, backdrop, and contact popover -->
    <script>
      const nav = document.getElementById('main-nav');
      const toggle = document.getElementById('mobile-nav-toggle');
      
      // Dynamic Backdrop Element creation
      let backdrop = document.getElementById('nav-backdrop');
      if (!backdrop) {
        backdrop = document.createElement('div');
        backdrop.id = 'nav-backdrop';
        backdrop.className = 'nav-backdrop';
        document.body.appendChild(backdrop);
      }
      
      // Scroll listener to transition header background and items
      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          nav?.classList.add('scrolled');
        } else {
          nav?.classList.remove('scrolled');
        }
      });
      
      // Mobile menu toggle
      if (toggle && nav) {
        toggle.addEventListener('click', () => {
          const isOpen = nav.classList.toggle('menu-open');
          if (isOpen) {
            backdrop.classList.add('active');
          } else {
            backdrop.classList.remove('active');
          }
        });
      }

      // Close menu when backdrop is clicked
      backdrop.addEventListener('click', () => {
        nav?.classList.remove('menu-open');
        backdrop.classList.remove('active');
      });

      // Close menu when links are clicked
      const links = document.querySelectorAll('.nav-links a');
      links.forEach(link => {
        link.addEventListener('click', () => {
          if (link.id !== 'nav-contact-btn') {
            nav?.classList.remove('menu-open');
            backdrop.classList.remove('active');
          }
        });
      });

      // Contact Popover Logic
      const contactBtn = document.getElementById('nav-contact-btn');
      const popover = document.getElementById('contact-popover');
      const copyBtn = document.getElementById('copy-email-btn');
      const emailText = document.getElementById('email-address');

      if (contactBtn && popover) {
        contactBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const isActive = popover.classList.toggle('active');
          popover.setAttribute('aria-hidden', isActive ? 'false' : 'true');
        });

        // Close popover when clicking anywhere else on the document
        document.addEventListener('click', (e) => {
          const target = e.target;
          if (target && !popover.contains(target as Node) && target !== contactBtn) {
            popover.classList.remove('active');
            popover.setAttribute('aria-hidden', 'true');
          }
        });

        // Close popover on Escape
        window.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            popover.classList.remove('active');
            popover.setAttribute('aria-hidden', 'true');
          }
        });
      }

      // Copy email functionality
      if (copyBtn && emailText) {
        copyBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          const email = emailText.textContent || 'info@okaloa.com';
          navigator.clipboard.writeText(email).then(() => {
            const btnText = copyBtn.querySelector('.copy-btn-text');
            if (btnText) {
              btnText.textContent = 'Copied!';
              copyBtn.classList.add('copied');
              setTimeout(() => {
                btnText.textContent = 'Copy';
                copyBtn.classList.remove('copied');
              }, 2000);
            }
          }).catch(err => {
            console.error('Failed to copy: ', err);
          });
        });
      }
    </script>
  </body>
</html>

<style>
  /* Navigation Bar (Scroll-sensitive) */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.6rem 2rem;
    background: rgba(37, 52, 55, 0); /* Transparent initially */
    border-bottom: 1px solid transparent;
    transition: background-color 0.25s ease, padding 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  
  .nav-container {
    max-width: var(--container-max-width);
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  /* Scrolled State: Transitions to solid white with dark text and borders */
  nav.scrolled {
    background-color: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    padding: 0.9rem 2rem;
    border-bottom: 1px solid var(--color-neutral-border);
    box-shadow: var(--shadow-sm);
  }
  
  .nav-left {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  
  /* Double logo swap based on scrolled state */
  .logo-dark {
    display: none;
  }
  .logo-light {
    display: block;
  }
  
  nav.scrolled .logo-light {
    display: none;
  }
  nav.scrolled .logo-dark {
    display: block;
  }
  
  .nav-links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  
  .nav-item {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.85); /* Initially light for dark hero */
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .nav-item:hover {
    color: var(--color-brand-red);
  }
  
  nav.scrolled .nav-item {
    color: var(--color-text-dark-muted); /* Turns dark when scrolled */
  }
  
  nav.scrolled .nav-item:hover {
    color: var(--color-brand-red);
  }
  
  /* Action Button */
  .contact-btn {
    background: var(--color-brand-red) !important;
    color: var(--color-neutral-white) !important;
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.92rem;
    transition: background 0.2s, transform 0.15s;
    display: inline-block;
  }
  
  .contact-btn:hover {
    background: var(--color-brand-red-hover) !important;
    transform: translateY(-1px);
  }
  
  /* Mobile Hamburger Toggle with 44px touch target */
  .nav-toggle {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 44px;
    height: 44px;
    padding: 10px;
    z-index: 110; /* Ensure toggle stays above backdrop and drawer links */
    margin-right: -10px; /* Visually offset the padding */
  }
  
  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-neutral-white); /* Initially white */
    transition: transform 0.25s, opacity 0.25s, background-color 0.25s;
  }
  
  nav.scrolled .nav-toggle span {
    background-color: var(--color-text-dark); /* Turns dark when scrolled */
  }
  
  /* Mobile Responsive styling */
  @media (max-width: 900px) {
    .nav-toggle {
      display: flex;
    }
    
    .nav-links {
      position: fixed;
      top: 0; right: 0;
      height: 100vh;
      width: min(80vw, 320px);
      background: rgba(37, 52, 55, 0.98); /* Always dark on mobile side-menu */
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding: 6rem 2rem 2rem;
      transform: translateX(100%);
      transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
      box-shadow: -10px 0 40px rgba(0, 0, 0, 0.3);
      z-index: 100; /* Ensure drawer is beneath toggle but above main page content */
    }
    
    nav.menu-open .nav-links {
      transform: translateX(0);
    }
    
    .nav-links li {
      width: 100%;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    
    .nav-links a {
      display: block;
      padding: 1rem 0;
      font-size: 1.05rem;
      color: rgba(255, 255, 255, 0.92) !important; /* Force white links in mobile overlay */
    }
    
    .nav-links .nav-contact-wrapper {
      border-bottom: none;
      width: 100%;
    }
    
    .nav-links .contact-btn {
      display: block;
      width: 100%;
      text-align: center;
      margin-top: 1.5rem;
      padding: 0.8rem 1.5rem;
      font-size: 1.05rem;
      border-bottom: none !important;
    }
    
    nav.menu-open .nav-toggle span:nth-child(1) {
      transform: translateY(8px) rotate(45deg);
    }
    
    nav.menu-open .nav-toggle span:nth-child(2) {
      opacity: 0;
    }
    
    nav.menu-open .nav-toggle span:nth-child(3) {
      transform: translateY(-8px) rotate(-45deg);
    }
    
    /* Scrolled state mobile hamburger toggle alignment */
    nav.scrolled.menu-open .nav-toggle span {
      background-color: var(--color-neutral-white); /* Keep white inside dark menu overlay */
    }
  }

  /* Full screen blur backdrop for click-outside close */
  .nav-backdrop {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 95; /* Behind the nav drawer (100) but above page content */
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  
  .nav-backdrop.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Footer Styling */
  .main-footer {
    background-color: var(--color-bg-dark-hero);
    color: var(--color-neutral-white);
    padding-top: var(--space-xxl);
    padding-bottom: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin-bottom: var(--space-xl);
  }
  
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 2fr;
    }
  }
  
  .footer-logo-img {
    margin-bottom: var(--space-sm);
  }
  
  .footer-tagline {
    font-size: 0.95rem;
    color: #a0aec0;
  }
  
  .footer-nav h4, .footer-contact h4 {
    font-size: 1.1rem;
    color: var(--color-neutral-white);
    margin-bottom: var(--space-md);
    font-family: var(--font-sans);
    font-weight: 700;
  }
  
  .footer-nav ul {
    list-style: none;
  }
  
  .footer-nav li {
    margin-bottom: var(--space-xs);
  }
  
  .footer-nav a {
    font-size: 0.95rem;
    color: #a0aec0;
  }
  
  .footer-nav a:hover {
    color: var(--color-brand-red);
  }
  
  .footer-contact p {
    font-size: 0.95rem;
    color: #a0aec0;
    margin-bottom: var(--space-sm);
  }
  
  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  
  .contact-link {
    color: #a0aec0;
    font-size: 0.95rem;
  }
  
  .contact-link:hover {
    color: var(--color-brand-red);
  }
  
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: var(--space-md);
    text-align: center;
    font-size: 0.9rem;
    color: #718096;
  }

  /* Contact Popover Styles */
  .nav-contact-wrapper {
    position: relative;
  }
  
  .contact-popover {
    position: absolute;
    top: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    z-index: 200;
    background-color: #2d3e41;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 0.8rem 1rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    min-width: 250px;
  }
  
  .contact-popover.active {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  
  /* Popover Arrow pointing up */
  .popover-arrow {
    position: absolute;
    top: -6px;
    left: 50%;
    width: 10px;
    height: 10px;
    background-color: #2d3e41;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    transform: translateX(-50%) rotate(45deg);
  }

  /* Scrolled state theme adjustment */
  nav.scrolled .contact-popover {
    background-color: var(--color-neutral-white);
    border-color: var(--color-neutral-border);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }
  
  nav.scrolled .popover-arrow {
    background-color: var(--color-neutral-white);
    border-left-color: var(--color-neutral-border);
    border-top-color: var(--color-neutral-border);
  }

  nav.scrolled .popover-email {
    color: var(--color-text-dark);
  }
  
  .popover-content {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    align-items: center;
  }
  
  .popover-email {
    font-family: monospace;
    font-size: 0.95rem;
    color: var(--color-neutral-white);
    user-select: all;
  }

  .popover-actions {
    display: flex;
    gap: 0.5rem;
    width: 100%;
  }

  .popover-btn {
    flex: 1;
    text-align: center;
    border: none;
    padding: 0.35rem 0.65rem;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  
  .popover-copy-btn {
    background: var(--color-brand-red);
    color: white;
  }
  
  .popover-copy-btn:hover {
    background: var(--color-brand-red-hover);
  }

  .popover-copy-btn.copied {
    background: #2f855a; /* Green success state */
  }

  .popover-mail-btn {
    background: rgba(255, 255, 255, 0.08);
    color: #a0aec0;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }
  
  .popover-mail-btn:hover {
    background: rgba(255, 255, 255, 0.15);
    color: white;
    border-color: rgba(255, 255, 255, 0.3);
  }

  /* Scrolled theme for secondary button */
  nav.scrolled .popover-mail-btn {
    background: rgba(0, 0, 0, 0.04);
    color: var(--color-text-dark-muted);
    border: 1px solid rgba(0, 0, 0, 0.1);
  }

  nav.scrolled .popover-mail-btn:hover {
    background: rgba(0, 0, 0, 0.08);
    color: var(--color-text-dark);
    border-color: rgba(0, 0, 0, 0.25);
  }

  /* Responsive positioning inside mobile drawer */
  @media (max-width: 900px) {
    .contact-popover {
      position: relative;
      top: auto;
      left: auto;
      transform: none !important;
      min-width: 100%;
      box-shadow: none;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background-color: rgba(255, 255, 255, 0.03);
      padding: 0.8rem;
      margin-top: 0.5rem;
      border-radius: 6px;
      display: none;
      opacity: 1;
      pointer-events: auto;
    }
    
    .contact-popover.active {
      display: block;
    }
    
    .popover-arrow {
      display: none; /* Hide arrow on mobile */
    }
  }
</style>
